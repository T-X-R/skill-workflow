# ========== 火山引擎 ASR (volcengine-asr) ==========
VOLCENGINE_APP_ID=YOUR_VOLCENGINE_APP_ID
VOLCENGINE_ACCESS_KEY=YOUR_VOLCENGINE_ACCESS_KEY
VOLCENGINE_API_RESOURCE_ID=YOUR_VOLCENGINE_API_RESOURCE_ID

# ========== 火山引擎工作流通用配置 (cloud-standardize-video / volc-sdr-enhance / volc-video-filter 共用) ==========
VOLCENGINE_WORKFLOW_ACCESS_KEY=YOUR_VOLCENGINE_WORKFLOW_ACCESS_KEY
VOLCENGINE_WORKFLOW_SECRET_KEY=YOUR_VOLCENGINE_WORKFLOW_SECRET_KEY
VOLCENGINE_WORKFLOW_REGION=YOUR_VOLCENGINE_REGION
VOLCENGINE_WORKFLOW_SPACE_NAME=YOUR_VOLCENGINE_WORKFLOW_SPACE_NAME

# ========== 云端视频标准化 (cloud-standardize-video) ==========
VOLCENGINE_TRANSCODING_TEMPLATE_ID=YOUR_VOLCENGINE_TRANSCODING_TEMPLATE_ID

# ========== 火山 SDR 增强 (volc-sdr-enhance) ==========
VOLCENGINE_SDR_TEMPLATE_ID=YOUR_VOLCENGINE_SDR_TEMPLATE_ID

# ========== 火山视频滤镜 (volc-video-filter) ==========
VOLCENGINE_FILTER_PROJECT_ID=YOUR_VOLCENGINE_FILTER_PROJECT_ID
VOLCENGINE_FILTER_GROUP_ID=YOUR_VOLCENGINE_FILTER_GROUP_ID

# ========== 阿里云 OSS (upload-to-oss) ==========
ALIYUN_OSS_ACCESS_KEY=YOUR_ALIYUN_OSS_ACCESS_KEY
ALIYUN_OSS_ACCESS_SECRET=YOUR_ALIYUN_OSS_ACCESS_SECRET
ALIYUN_OSS_BUCKET=YOUR_ALIYUN_OSS_BUCKET
ALIYUN_OSS_ENDPOINT=YOUR_ALIYUN_OSS_ENDPOINT

# ========== 阿里云 ICE 美颜服务 (ali-face-beauty) ==========
ALIYUN_ICE_ACCESS_KEY=YOUR_ALIYUN_ICE_ACCESS_KEY
ALIYUN_ICE_ACCESS_SECRET=YOUR_ALIYUN_ICE_ACCESS_SECRET
ALIYUN_ICE_ENDPOINT=YOUR_ALIYUN_ICE_ENDPOINT

# ========== agent ==========
API_KEY=YOUR_API_KEY
BASE_URL=YOUR_BASE_URL
MODEL=YOUR_MODEL

# ========== sub-agent profiles ==========
# key = skill 的 preferred_model 字段值；可配置多个 profile 指向不同模型/端点
# 格式：{"profile_name": {"api_key": "...", "base_url": "...", "model": "..."}, ...}
LLM_PROFILES={"PROFILE_NAME": {"api_key": "YOUR_API_KEY", "base_url": "YOUR_BASE_URL", "model": "YOUR_MODEL"}}
